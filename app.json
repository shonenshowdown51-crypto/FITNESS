{
  "name": "LevelUp Training",
  "slug": "levelup-training",
  "version": "1.0.0",
  "orientation": "portrait",
  "icon": "./assets/images/icon.png",
  "scheme": "myapp",
  "userInterfaceStyle": "dark",
  "newArchEnabled": true,

  "ios": {
    "supportsTablet": true
  },

  "android": {
    "package": "com.swastik.leveluptraining",
    "permissions": [
      "android.permission.RECORD_AUDIO",
      "android.permission.MODIFY_AUDIO_SETTINGS"
    ]
  },

  "web": {
    "bundler": "metro",
    "output": "single",
    "favicon": "./assets/images/favicon.png"
  },

  "plugins": [
    "expo-router",
    "expo-font",
    "expo-web-browser",
    "expo-av"
  ],

  "experiments": {
    "typedRoutes": true
  },

  "extra": {
    "router": {},
    "eas": {
      "projectId": "f43e7c7a-cf72-4e36-9f95-29cef273fa72"
    }
  },

  "sdkVersion": "54.0.0",

  "platforms": [
    "ios",
    "android",
    "web"
  ]
}
